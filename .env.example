# ─────────────────────────────────────────────────────────────────────────────
# VMBS Branch Defects & Operational Standard Tracker — environment configuration
# Copy to .env.local for local dev; set these in Vercel for deploys.
# ─────────────────────────────────────────────────────────────────────────────

# Secret used to sign the admin session cookie (any long random string).
# REQUIRED in production. Generate: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string

# Admin password for the Settings page. OPTIONAL — there is a built-in default
# ("admin") so sign-in works with no configuration at all. Set this to override
# the default. Once an admin changes it in-app (Settings → Admin password), the
# new password is hashed (scrypt) and persisted to storage (admin-credentials.json)
# and takes precedence over this value.
ADMIN_PASSWORD=change-me

# ── Vercel Blob storage ──────────────────────────────────────────────────────
# BLOB_READ_WRITE_TOKEN is injected automatically when you connect a Vercel Blob
# store to the project. With no token set, the app uses a local ./.data folder
# (dev only) so `next dev` works without cloud storage.
BLOB_READ_WRITE_TOKEN=
